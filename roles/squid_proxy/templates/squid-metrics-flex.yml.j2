---
# /etc/newrelic-infra/integrations.d/squid-metrics.yml
# Managed by Ansible - New Relic Squid Proxy (N4 Feature)
#
# Generates metrics from Squid's built-in Cache Manager
# using the New Relic Infrastructure Flex Integration.

integrations:
  - name: nri-flex
    interval: 30s
    config:
      name: SquidProxyMetrics
      apis:
        - name: SquidCounters
          commands:
            - run: curl -s "http://localhost:{{ squid_port }}/squid-internal-mgr/counters" | awk -F" = " 'BEGIN {print "{"} /^[a-zA-Z_.]+ = [0-9.]+$/ {printf "\"%s\":%s,\n", $1, $2} END {print "\"status\":\"ok\"}"}'
          sample_name: SquidCounterSample
          custom_attributes:
            proxy_port: "{{ squid_port }}"
            proxy_host: "{{ ansible_fqdn | default(ansible_hostname) }}"

        - name: SquidInfo
          commands:
            - run: curl -s "http://localhost:{{ squid_port }}/squid-internal-mgr/info" | awk -F':' 'BEGIN {print "{"} /^[ \t]*([^:]+):[ \t]*([0-9.]+)[^0-9]*$/ { key=$1; sub(/^[ \t]+/, "", key); val=$2; sub(/^[ \t]+/, "", val); sub(/[^0-9.].*$/, "", val); printf "\"%s\":%s,\n", key, val } END {print "\"status\":\"ok\"}"}'
          sample_name: SquidInfoSample
          custom_attributes:
            proxy_port: "{{ squid_port }}"
            proxy_host: "{{ ansible_fqdn | default(ansible_hostname) }}"
