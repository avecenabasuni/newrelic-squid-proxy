#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# New Relic Squid Proxy — Automated Root CA Rotation
# Auto-generated by Ansible
# ═══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

CERT_DEST="{{ ssl_bump_cert_dest }}"
KEY_DEST="{{ ssl_bump_key_dest }}"
SSL_DB="{{ ssl_bump_db_path }}"
CERTGEN="{{ squid_certgen_path }}"
SQUID_USER="{{ squid_user }}"
SQUID_GROUP="{{ squid_group }}"

# Rotate CA if it expires within 30 days (2592000 seconds)
EXPIRY_SECONDS=2592000

if openssl x509 -checkend $EXPIRY_SECONDS -noout -in "$CERT_DEST" >/dev/null 2>&1; then
    # Certificate is valid for more than 30 days
    exit 0
fi

echo "[$(date)] CA certificate expiring soon. Rotating..."

# 1. Stop Squid
systemctl stop squid

# 2. Back up old CA
cp "$CERT_DEST" "${CERT_DEST}.old"
cp "$KEY_DEST" "${KEY_DEST}.old"

# 3. Generate new CA
openssl req -new -newkey rsa:2048 -days 365 -nodes -x509 \
    -subj "/C=US/ST=State/L=City/O=New Relic Squid Proxy/CN=NewRelic-Squid-Proxy-CA" \
    -keyout "$KEY_DEST" -out "$CERT_DEST" >/dev/null 2>&1

chmod 644 "$CERT_DEST"
chmod 600 "$KEY_DEST"
chown $SQUID_USER:$SQUID_GROUP "$CERT_DEST" "$KEY_DEST"

# 4. Rebuild SSL DB
echo "[$(date)] Rebuilding SSL DB..."
rm -rf "$SSL_DB"
$CERTGEN -c -s "$SSL_DB" -M 4MB >/dev/null 2>&1
chown -R $SQUID_USER:$SQUID_GROUP "$SSL_DB"

# 5. Start Squid
systemctl start squid

echo "[$(date)] CA rotation complete. IMPORTANT: New Root CA must be distributed to clients."
