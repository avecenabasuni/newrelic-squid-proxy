{
  "name": "Squid Proxy Monitoring",
  "description": "Real-time observability dashboard for Squid forward proxy \u2014 powered by nri-flex Cache Manager integration",
  "permissions": "PUBLIC_READ_WRITE",
  "variables": [
    {
      "name": "proxy_host",
      "title": "Proxy Host",
      "type": "NRQL",
      "nrqlQuery": {
        "accountIds": [],
        "query": "SELECT uniques(proxy_host) FROM SquidCountersSample"
      },
      "replacementStrategy": "DEFAULT"
    }
  ],
  "pages": [
    {
      "name": "Overview",
      "description": "Core proxy health and traffic metrics",
      "widgets": [
        {
          "title": "Total HTTP Requests",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(client_http.requests) AS 'Client Requests', latest(server.all.requests) AS 'Server Requests' FROM SquidCountersSample SINCE 30 minutes ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Client Errors",
          "layout": { "column": 4, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(client_http.errors) AS 'Client Errors', latest(server.all.errors) AS 'Server Errors', latest(aborted_requests) AS 'Aborted' FROM SquidCountersSample SINCE 30 minutes ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 10 },
              { "alertSeverity": "CRITICAL", "value": 50 }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Active Clients",
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(`Number of clients accessing cache`) AS 'Active Clients', latest(`Average HTTP requests per minute since start`) AS 'Req/min Avg' FROM SquidInfoSample SINCE 30 minutes ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Proxy Uptime",
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(`UP Time`) / 3600 AS 'Uptime (hours)' FROM SquidInfoSample SINCE 30 minutes ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "HTTP Request Volume",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "yAxisLeft": { "zero": true },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(client_http.requests) AS 'Client Requests', latest(server.all.requests) AS 'Server Requests' FROM SquidCountersSample TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Bandwidth (KB)",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.area" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(client_http.kbytes_in) AS 'Client KB In', latest(client_http.kbytes_out) AS 'Client KB Out', latest(server.all.kbytes_in) AS 'Server KB In', latest(server.all.kbytes_out) AS 'Server KB Out' FROM SquidCountersSample TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Error Trend",
          "layout": { "column": 1, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "colors": {
              "seriesOverrides": [
                { "seriesName": "Client Errors", "color": "#e74c3c" },
                { "seriesName": "Server Errors", "color": "#f39c12" }
              ]
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(client_http.errors) AS 'Client Errors', latest(server.all.errors) AS 'Server Errors', latest(aborted_requests) AS 'Aborted' FROM SquidCountersSample TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "CPU Usage (%)",
          "layout": { "column": 5, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(`CPU Usage`) AS 'CPU %', latest(`CPU Usage, 5 minute avg`) AS 'CPU 5m Avg', latest(`CPU Usage, 60 minute avg`) AS 'CPU 60m Avg' FROM SquidInfoSample TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Memory (KB)",
          "layout": { "column": 9, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(`Maximum Resident Size`) AS 'RSS (KB)', latest(`Storage Mem size`) AS 'Cache Mem (KB)', latest(`Storage Swap size`) AS 'Cache Swap (KB)' FROM SquidInfoSample TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "File Descriptors",
          "layout": { "column": 1, "row": 10, "width": 4, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(`Number of file desc currently in use`) AS 'In Use', latest(`Available number of file descriptors`) AS 'Available', latest(`Reserved number of file descriptors`) AS 'Reserved' FROM SquidInfoSample SINCE 30 minutes ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "ICP / Cache Digest Activity",
          "layout": { "column": 5, "row": 10, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(icp.pkts_sent) AS 'ICP Sent', latest(icp.pkts_recv) AS 'ICP Recv', latest(cd.msgs_sent) AS 'CD Sent', latest(cd.msgs_recv) AS 'CD Recv' FROM SquidCountersSample TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Proxy Runtime Summary",
          "layout": { "column": 9, "row": 10, "width": 4, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT latest(proxy_host) AS 'Host', latest(proxy_port) AS 'Port', latest(cpu_time) AS 'CPU Time (s)', latest(wall_time) AS 'Wall Time (s)', latest(select_loops) AS 'Select Loops', latest(swap.outs) AS 'Swap Outs', latest(swap.ins) AS 'Swap Ins' FROM SquidCountersSample SINCE 30 minutes ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        }
      ]
    }
  ]
}
